@page "/"
@inject BlazorFrontend.Services.ApiService ApiService

<PageTitle>Dashboard | E-Commerce Store</PageTitle>

<div class="container-fluid px-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="dashboard-card">
                <div class="text-center">
                    <i class="fas fa-store fa-4x" style="color: #667eea;"></i>
                    <h2 class="mt-3">Welcome to E-Commerce Store</h2>
                </div>
                <hr />
                <div class="row mt-4">
                    <div class="col-md-4">
                        <div class="dashboard-card bg-light">
                            <i class="fas fa-box fa-3x" style="color: #667eea;"></i>
                            <div class="stat-number">@totalProducts</div>
                            <p>Total Products</p>
                            <a href="/products" class="btn btn-sm btn-outline-primary">Manage Products</a>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="dashboard-card bg-light">
                            <i class="fas fa-users fa-3x" style="color: #764ba2;"></i>
                            <div class="stat-number">@totalCustomers</div>
                            <p>Total Customers</p>
                            <a href="/customers" class="btn btn-sm btn-outline-primary">Manage Customers</a>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="dashboard-card bg-light">
                            <i class="fas fa-shopping-cart fa-3x" style="color: #11998e;"></i>
                            <div class="stat-number">@totalOrders</div>
                            <p>Total Orders</p>
                            <a href="/orders" class="btn btn-sm btn-outline-primary">Manage Orders</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="dashboard-card">
                <h5><i class="fas fa-bolt text-warning me-2"></i>Quick Actions</h5>
                <hr />
                <div class="row">
                    <div class="col-md-4 mb-2">
                        <a href="/products" class="btn btn-outline-primary w-100 py-3">
                            <i class="fas fa-plus-circle me-2"></i>Add New Product
                        </a>
                    </div>
                    <div class="col-md-4 mb-2">
                        <a href="/customers" class="btn btn-outline-info w-100 py-3">
                            <i class="fas fa-user-plus me-2"></i>Add New Customer
                        </a>
                    </div>
                    <div class="col-md-4 mb-2">
                        <a href="/orders" class="btn btn-outline-success w-100 py-3">
                            <i class="fas fa-cart-plus me-2"></i>Create New Order
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private int totalProducts = 0;
    private int totalCustomers = 0;
    private int totalOrders = 0;

    protected override async Task OnInitializedAsync()
    {
        var products = await ApiService.GetProductsAsync();
        var customers = await ApiService.GetCustomersAsync();
        var orders = await ApiService.GetOrdersAsync();

        totalProducts = products?.Count ?? 0;
        totalCustomers = customers?.Count ?? 0;
        totalOrders = orders?.Count ?? 0;
    }
}

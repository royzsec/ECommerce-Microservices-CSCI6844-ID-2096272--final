@page "/orders"
@using BlazorFrontend.Models
@inject BlazorFrontend.Services.ApiService ApiService

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-shopping-cart text-success me-2"></i> Orders Management</h2>
        <button class="btn btn-primary" @onclick="() => showCreateForm = true">
            <i class="fas fa-plus-circle me-2"></i>Create New Order
        </button>
    </div>

    @if (showCreateForm)
    {
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title mb-3">Create New Order</h5>
                <div class="row">
                    <div class="col-md-3 mb-3">
                        <label class="form-label fw-bold">Customer ID</label>
                        <input @bind="newOrder.CustomerId" type="number" class="form-control" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label fw-bold">Product ID</label>
                        <input @bind="newOrder.ProductId" type="number" class="form-control" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label fw-bold">Quantity</label>
                        <input @bind="newOrder.Quantity" type="number" class="form-control" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <button class="btn btn-success w-100 mt-4" @onclick="CreateOrder">Place Order</button>
                    </div>
                </div>
                <button class="btn btn-secondary btn-sm" @onclick="CancelCreateForm">Cancel</button>
            </div>
        </div>
    }

    @if (isLoading)
    {
        <div class="text-center py-5">
            <i class="fas fa-spinner fa-spin fa-3x text-primary"></i>
            <p>Loading orders...</p>
        </div>
    }
    else if (orders.Count == 0)
    {
        <div class="alert alert-info text-center">
            <i class="fas fa-info-circle me-2"></i>No orders found. Click "Create New Order" to place one.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Customer ID</th>
                        <th>Product ID</th>
                        <th>Quantity</th>
                        <th>Total Price</th>
                        <th>Status</th>
                        <th>Created At</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in orders)
                    {
                        <tr>
                            <td>@order.Id</td
                            <td>@order.CustomerId</td
                            <td>@order.ProductId</td
                            <td>@order.Quantity</td
                            <td class="text-success fw-bold">$@order.TotalPrice</td
                            <td>
                                @if (order.Status == "Created")
                                {
                                    <span class="badge bg-success">Created</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Cancelled</span>
                                }
                            </td
                            <td>@order.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td
                            <td>
                                @if (order.Status == "Created")
                                {
                                    <button class="btn btn-warning btn-sm me-1" @onclick="() => CancelOrder(order.Id)">
                                        <i class="fas fa-ban"></i> Cancel
                                    </button>
                                }
                                <button class="btn btn-danger btn-sm" @onclick="() => DeleteOrder(order.Id)">
                                    <i class="fas fa-trash"></i> Delete
                                </button>
                            </td
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<OrderResponseDto> orders = new();
    private bool isLoading = true;
    private bool showCreateForm = false;
    private CreateOrderDto newOrder = new CreateOrderDto();

    protected override async Task OnInitializedAsync()
    {
        await LoadOrders();
    }

    private async Task LoadOrders()
    {
        isLoading = true;
        orders = await ApiService.GetOrdersAsync() ?? new List<OrderResponseDto>();
        isLoading = false;
        StateHasChanged();
    }

    private void CancelCreateForm()
    {
        showCreateForm = false;
        newOrder = new CreateOrderDto();
    }

    private async Task CreateOrder()
    {
        if (newOrder.CustomerId <= 0 || newOrder.ProductId <= 0 || newOrder.Quantity <= 0) return;
        await ApiService.CreateOrderAsync(newOrder);
        await LoadOrders();
        CancelCreateForm();
    }

    private async Task CancelOrder(int id)
    {
        var result = await ApiService.CancelOrderAsync(id);
        if (result != null)
        {
            await LoadOrders();
        }
    }

    private async Task DeleteOrder(int id)
    {
        if (await ApiService.DeleteOrderAsync(id))
        {
            await LoadOrders();
        }
    }
}

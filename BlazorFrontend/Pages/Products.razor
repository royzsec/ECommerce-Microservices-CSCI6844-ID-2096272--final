@page "/products"
@using BlazorFrontend.Models
@inject BlazorFrontend.Services.ApiService ApiService

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-box text-primary me-2"></i> Products Management</h2>
        <button class="btn btn-primary" @onclick="() => showCreateForm = true">
            <i class="fas fa-plus-circle me-2"></i>Add New Product
        </button>
    </div>

    @if (showCreateForm)
    {
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title mb-3">Create New Product</h5>
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold">Product Name</label>
                        <input @bind="newProduct.Name" class="form-control" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label fw-bold">Price ($)</label>
                        <input @bind="newProduct.Price" type="number" step="0.01" class="form-control" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label fw-bold">Stock Quantity</label>
                        <input @bind="newProduct.Stock" type="number" class="form-control" />
                    </div>
                    <div class="col-md-2 mb-3">
                        <button class="btn btn-success w-100 mt-4" @onclick="CreateProduct">Save</button>
                    </div>
                </div>
                <button class="btn btn-secondary btn-sm" @onclick="CancelCreateForm">Cancel</button>
            </div>
        </div>
    }

    @if (isLoading)
    {
        <div class="text-center py-5">
            <i class="fas fa-spinner fa-spin fa-3x text-primary"></i>
            <p>Loading products...</p>
        </div>
    }
    else if (products.Count == 0)
    {
        <div class="alert alert-info text-center">
            <i class="fas fa-info-circle me-2"></i>No products found. Click "Add New Product" to create one.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var product in products)
            {
                <div class="col-md-4 col-lg-3 mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <div class="text-center mb-3">
                                <i class="fas fa-box fa-3x" style="color: #667eea;"></i>
                            </div>
                            
                            @if (editingProductId == product.Id)
                            {
                                <div>
                                    <input @bind="editProduct.Name" class="form-control mb-2" placeholder="Name" />
                                    <input @bind="editProduct.Price" type="number" step="0.01" class="form-control mb-2" placeholder="Price" />
                                    <input @bind="editProduct.Stock" type="number" class="form-control mb-2" placeholder="Stock" />
                                    <button class="btn btn-success btn-sm me-2" @onclick="() => UpdateProduct(product.Id)">Save</button>
                                    <button class="btn btn-secondary btn-sm" @onclick="CancelEdit">Cancel</button>
                                </div>
                            }
                            else
                            {
                                <h5 class="card-title text-center">@product.Name</h5>
                                <hr />
                                <p><strong>Price:</strong> $@product.Price.ToString("F2")</p>
                                <p><strong>Stock:</strong> @product.Stock units</p>
                                <p><strong>ID:</strong> #@product.Id</p>
                                <div class="btn-group w-100">
                                    <button class="btn btn-warning btn-sm" @onclick="() => StartEdit(product)">
                                        <i class="fas fa-edit"></i> Edit
                                    </button>
                                    <button class="btn btn-danger btn-sm" @onclick="() => DeleteProduct(product.Id)">
                                        <i class="fas fa-trash"></i> Delete
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<ProductDto> products = new();
    private bool isLoading = true;
    private bool showCreateForm = false;
    private ProductDto newProduct = new ProductDto();
    private int editingProductId = 0;
    private ProductDto editProduct = new ProductDto();

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        isLoading = true;
        products = await ApiService.GetProductsAsync() ?? new List<ProductDto>();
        isLoading = false;
        StateHasChanged();
    }

    private void CancelCreateForm()
    {
        showCreateForm = false;
        newProduct = new ProductDto();
    }

    private async Task CreateProduct()
    {
        if (string.IsNullOrWhiteSpace(newProduct.Name)) return;
        await ApiService.CreateProductAsync(newProduct);
        await LoadProducts();
        CancelCreateForm();
    }

    private void StartEdit(ProductDto product)
    {
        editingProductId = product.Id;
        editProduct = new ProductDto
        {
            Id = product.Id,
            Name = product.Name,
            Price = product.Price,
            Stock = product.Stock
        };
    }

    private void CancelEdit()
    {
        editingProductId = 0;
        editProduct = new ProductDto();
    }

    private async Task UpdateProduct(int id)
    {
        await ApiService.UpdateProductAsync(id, editProduct);
        await LoadProducts();
        CancelEdit();
    }

    private async Task DeleteProduct(int id)
    {
        if (await ApiService.DeleteProductAsync(id))
        {
            await LoadProducts();
        }
    }
}

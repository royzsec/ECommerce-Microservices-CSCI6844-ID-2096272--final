@page "/customers"
@using BlazorFrontend.Models
@inject BlazorFrontend.Services.ApiService ApiService

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-users text-info me-2"></i> Customers Management</h2>
        <button class="btn btn-primary" @onclick="() => showForm = true">
            <i class="fas fa-user-plus me-2"></i>Add New Customer
        </button>
    </div>

    @if (showForm)
    {
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title mb-3">Create New Customer</h5>
                <div class="row">
                    <div class="col-md-5 mb-3">
                        <label class="form-label fw-bold">Full Name</label>
                        <input @bind="newCustomerName" class="form-control" />
                    </div>
                    <div class="col-md-5 mb-3">
                        <label class="form-label fw-bold">Email Address</label>
                        <input @bind="newCustomerEmail" class="form-control" />
                    </div>
                    <div class="col-md-2 mb-3">
                        <button class="btn btn-success w-100 mt-4" @onclick="CreateCustomer">Save</button>
                    </div>
                </div>
                <button class="btn btn-secondary btn-sm" @onclick="CancelForm">Cancel</button>
            </div>
        </div>
    }

    @if (isLoading)
    {
        <div class="text-center py-5">
            <i class="fas fa-spinner fa-spin fa-3x text-primary"></i>
            <p>Loading customers...</p>
        </div>
    }
    else if (customers.Count == 0)
    {
        <div class="alert alert-info text-center">
            <i class="fas fa-info-circle me-2"></i>No customers found.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var customer in customers)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <div class="text-center mb-3">
                                <i class="fas fa-user-circle fa-4x" style="color: #764ba2;"></i>
                            </div>
                            <h5 class="card-title text-center">@customer.Name</h5>
                            <hr />
                            <p><strong>Email:</strong> @customer.Email</p>
                            <p><strong>ID:</strong> #@customer.Id</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<CustomerDto> customers = new();
    private bool isLoading = true;
    private bool showForm = false;
    private string newCustomerName = "";
    private string newCustomerEmail = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadCustomers();
    }

    private async Task LoadCustomers()
    {
        isLoading = true;
        customers = await ApiService.GetCustomersAsync();
        isLoading = false;
        StateHasChanged();
    }

    private void CancelForm()
    {
        showForm = false;
        newCustomerName = "";
        newCustomerEmail = "";
    }

    private async Task CreateCustomer()
    {
        if (string.IsNullOrWhiteSpace(newCustomerName) || string.IsNullOrWhiteSpace(newCustomerEmail))
        {
            return;
        }

        var customer = new CustomerDto
        {
            Name = newCustomerName,
            Email = newCustomerEmail
        };

        await ApiService.CreateCustomerAsync(customer);
        await LoadCustomers();
        CancelForm();
    }
}

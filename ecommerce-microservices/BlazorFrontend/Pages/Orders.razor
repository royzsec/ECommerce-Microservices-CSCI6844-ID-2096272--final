@page "/orders"
@using BlazorFrontend.Models
@inject BlazorFrontend.Services.ApiService ApiService

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-shopping-cart text-success me-2"></i> Orders Management</h2>
        <button class="btn btn-primary" @onclick="ToggleForm">
            <i class="fas fa-plus-circle me-2"></i>Create New Order
        </button>
    </div>

    @if (showForm)
    {
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title mb-3"><i class="fas fa-cart-plus text-success me-2"></i>Create New Order</h5>
                <div class="row">
                    <div class="col-md-3 mb-3">
                        <label class="form-label fw-bold">Customer ID</label>
                        <input @bind="newOrder.CustomerId" type="number" class="form-control" placeholder="Enter customer ID" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label fw-bold">Product ID</label>
                        <input @bind="newOrder.ProductId" type="number" class="form-control" placeholder="Enter product ID" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label fw-bold">Quantity</label>
                        <input @bind="newOrder.Quantity" type="number" class="form-control" placeholder="Enter quantity" />
                    </div>
                    <div class="col-md-3 mb-3 d-flex align-items-end">
                        <button class="btn btn-success w-100" @onclick="CreateOrder">
                            <i class="fas fa-check-circle me-2"></i>Place Order
                        </button>
                    </div>
                </div>
                <button class="btn btn-secondary btn-sm" @onclick="ToggleForm">
                    <i class="fas fa-times me-2"></i>Cancel
                </button>
            </div>
        </div>
    }

    @if (orders == null)
    {
        <div class="text-center py-5">
            <i class="fas fa-spinner fa-spin fa-3x text-primary"></i>
            <p class="mt-3">Loading orders...</p>
        </div>
    }
    else if (orders.Count == 0)
    {
        <div class="alert alert-info text-center">
            <i class="fas fa-info-circle me-2"></i>No orders found. Click "Create New Order" to place one.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th><i class="fas fa-hashtag"></i> Order ID</th>
                        <th><i class="fas fa-user"></i> Customer ID</th>
                        <th><i class="fas fa-box"></i> Product ID</th>
                        <th><i class="fas fa-calculator"></i> Quantity</th>
                        <th><i class="fas fa-dollar-sign"></i> Total Price</th>
                        <th><i class="fas fa-chart-line"></i> Status</th>
                        <th><i class="fas fa-calendar"></i> Created At</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in orders)
                    {
                        <tr>
                            <td><span class="badge bg-secondary">#@order.Id</span></td>
                            <td>@order.CustomerId</td>
                            <td>@order.ProductId</td>
                            <td>@order.Quantity</td>
                            <td class="text-success fw-bold">$@order.TotalPrice</td>
                            <td>
                                @if (order.Status == "Created")
                                {
                                    <span class="badge bg-success"><i class="fas fa-check"></i> @order.Status</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger"><i class="fas fa-times"></i> @order.Status</span>
                                }
                            </td>
                            <td>@order.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<OrderResponseDto>? orders;
    private bool showForm = false;
    private CreateOrderDto newOrder = new CreateOrderDto();

    protected override async Task OnInitializedAsync()
    {
        await LoadOrders();
    }

    private async Task LoadOrders()
    {
        orders = await ApiService.GetOrdersAsync() ?? new List<OrderResponseDto>();
        StateHasChanged();
    }

    private void ToggleForm()
    {
        showForm = !showForm;
        if (!showForm) newOrder = new CreateOrderDto();
    }

    private async Task CreateOrder()
    {
        if (newOrder.CustomerId <= 0 || newOrder.ProductId <= 0 || newOrder.Quantity <= 0)
        {
            return;
        }
        await ApiService.CreateOrderAsync(newOrder);
        await LoadOrders();
        ToggleForm();
    }
}

@page "/products"
@using BlazorFrontend.Models
@inject BlazorFrontend.Services.ApiService ApiService

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-box text-primary me-2"></i> Products Management</h2>
        <button class="btn btn-primary" @onclick="() => showForm = true">
            <i class="fas fa-plus-circle me-2"></i>Add New Product
        </button>
    </div>

    @if (showForm)
    {
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title mb-3">Create New Product</h5>
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold">Product Name</label>
                        <input @bind="newProductName" class="form-control" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label fw-bold">Price ($)</label>
                        <input @bind="newProductPrice" type="number" step="0.01" class="form-control" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label fw-bold">Stock Quantity</label>
                        <input @bind="newProductStock" type="number" class="form-control" />
                    </div>
                    <div class="col-md-2 mb-3">
                        <button class="btn btn-success w-100 mt-4" @onclick="CreateProduct">Save</button>
                    </div>
                </div>
                <button class="btn btn-secondary btn-sm" @onclick="CancelForm">Cancel</button>
            </div>
        </div>
    }

    @if (isLoading)
    {
        <div class="text-center py-5">
            <i class="fas fa-spinner fa-spin fa-3x text-primary"></i>
            <p>Loading products...</p>
        </div>
    }
    else if (products.Count == 0)
    {
        <div class="alert alert-info text-center">
            <i class="fas fa-info-circle me-2"></i>No products found.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var product in products)
            {
                <div class="col-md-4 col-lg-3 mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <div class="text-center mb-3">
                                <i class="fas fa-box fa-3x" style="color: #667eea;"></i>
                            </div>
                            <h5 class="card-title text-center">@product.Name</h5>
                            <hr />
                            <p><strong>Price:</strong> $@product.Price.ToString("F2")</p>
                            <p><strong>Stock:</strong> @product.Stock units</p>
                            <p><strong>ID:</strong> #@product.Id</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<ProductDto> products = new();
    private bool isLoading = true;
    private bool showForm = false;
    private string newProductName = "";
    private decimal newProductPrice = 0;
    private int newProductStock = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        isLoading = true;
        products = await ApiService.GetProductsAsync();
        isLoading = false;
        StateHasChanged();
    }

    private void CancelForm()
    {
        showForm = false;
        newProductName = "";
        newProductPrice = 0;
        newProductStock = 0;
    }

    private async Task CreateProduct()
    {
        if (string.IsNullOrWhiteSpace(newProductName))
        {
            return;
        }

        var product = new ProductDto
        {
            Name = newProductName,
            Price = newProductPrice,
            Stock = newProductStock
        };

        await ApiService.CreateProductAsync(product);
        await LoadProducts();
        CancelForm();
    }
}
